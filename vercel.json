{
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/inpaint.py": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/remove_bg.py": {
      "maxDuration": 120,
      "memory": 512
    },
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/inpaint", "destination": "/api/inpaint" },
    { "source": "/api/remove_bg", "destination": "/api/remove_bg" },
    { "source": "/api/(.*)", "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/wheels/(.*\\.png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
      ]
    },
    {
      "source": "/wheels/catalog.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
